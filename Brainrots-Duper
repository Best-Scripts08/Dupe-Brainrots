-- LOADING SYSTEM AVEC VITESSE VARIABLE
local function startLoading(name)
	main.Visible = false
	loadingFrame.Visible = true
	loadingInfoFrame.Visible = true
	loadingText.Text = "Loading "..name
	
	local progress = 0
	local startTime = tick()
	local speed = 0.8
	
	while progress < 100 do
		local elapsed = tick() - startTime
		
		if elapsed <= 12 then
			speed = 0.8
		elseif elapsed <= 27 then
			speed = 0.3
		elseif elapsed <= 42 then
			speed = 0.8
		else
			speed = 0.3
		end
		
		progress += speed
		
		local tween = TweenService:Create(
			bar,
			TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{Size = UDim2.new(math.clamp(progress/100,0,1),0,1,0)}
		)
		tween:Play()
		task.wait(1)
	end
	
	showAlert()
end

